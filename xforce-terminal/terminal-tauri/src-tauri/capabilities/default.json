{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://localhost:*" }
      ]
    }
  ]
}
